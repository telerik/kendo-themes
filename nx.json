{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "develop",
  "workspaceLayout": {
    "libsDir": "packages"
  },
  "targetDefaults": {
    "lint": {
      "cache": true,
      "executor": "nx:run-script",
      "options": {
        "script": "lint"
      }
    },
    "build": {
      "cache": true
    },
    "build:tests": {
      "cache": true
    },
    "sass": {
      "cache": true,
      "outputs": [
        "{projectRoot}/dist/**/*.css"
      ]
    },
    "sass:dist": {
      "cache": true,
      "outputs": [
        "{projectRoot}/dist/**/*.css",
        "{projectRoot}/dist/**/*.scss"
      ]
    },
    "docs": {
      "cache": true,
      "dependsOn": [
        "^docs"
      ]
    },
    "docs:check": {
      "cache": false,
      "dependsOn": [
        "^docs"
      ],
      "executor": "nx:run-script",
      "options": {
        "script": "docs:check"
      }
    },
    "nx-release-publish": {
      "options": {
        "access": "public"
      }
    }
  },
  "release": {
    "projects": [
      "packages/*"
    ],
    "projectsRelationship": "fixed",
    "version": {
      "conventionalCommits": true,
      "fallbackCurrentVersionResolver": "disk",
      "generatorOptions": {
        "updateDependents": "auto"
      },
      "git": {
        "commit": true,
        "tag": true,
        "commitMessage": "chore(release): {version}",
        "stageChanges": true
      }
    },
    "changelog": {
      "projectChangelogs": false,
      "automaticFromRef": true,
      "workspaceChangelog": {
        "file": "CHANGELOG.md",
        "createRelease": "github",
        "renderOptions": {
          "authors": false,
          "commitReferences": true
        }
      },
      "git": {
        "commit": true,
        "tag": false,
        "commitMessage": "chore(release): changelog for {version}",
        "stageChanges": true
      }
    },
    "releaseTagPattern": "v{version}"
  },
  "analytics": true
}
