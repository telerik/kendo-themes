{
    "ariaSpec": [
        {
            "selector": ".k-stepper",
            "attribute": "role=navigation or nodeName=nav",
            "usage": "The landmark role navigation must be assigned to the component."
        },
        {
            "selector": ".k-step.k-disabled>.k-step-link",
            "attribute": "aria-disabled=true",
            "usage": "A disabled (inactive) link."
        },
        {
            "selector": ".k-step-current>.k-step-link",
            "attribute": "aria-current=step",
            "usage": "The currently selected link."
        },
        {
            "selector": ".k-step.k-focus .k-step-link",
            "attribute": "tabindex=0",
            "usage": "Focused step link is in the tab order."
        },
        {
            "selector": ".k-step:not(.k-focus) .k-step-link",
            "attribute": "tabindex=-1",
            "usage": "Non-focused step links are removed from tab order."
        }
    ],
    "kbSpec": [
        {
            "shortcut": "Shift + Tab",
            "behavior": "Focuses previous link."
        },
        {
            "shortcut": "Tab",
            "behavior": "Focuses next link."
        },
        {
            "shortcut": "Home",
            "behavior": "Focuses first link."
        },
        {
            "shortcut": "End",
            "behavior": "Focuses last link."
        },
        {
            "shortcut": "Space / Enter",
            "behavior": "Activates the currently focused link."
        }
    ]
}
