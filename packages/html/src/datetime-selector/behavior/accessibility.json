{
    "ariaSpec": [
        {
            "selector": ".k-datetime-wrap",
            "attribute": "role=group",
            "usage": "Groups the date/time selector components."
        },
        {
            "selector": ".k-datetime-wrap",
            "attribute": "aria-label",
            "usage": "Describes the date/time selector purpose."
        },
        {
            "selector": ".k-datetime-buttongroup",
            "attribute": "role=group",
            "usage": "The segmented control acts as a group for Date/Time selection."
        },
        {
            "selector": ".k-datetime-buttongroup .k-segmented-control-button",
            "attribute": "aria-pressed",
            "usage": "Indicates which option is currently active."
        }
    ]
}
