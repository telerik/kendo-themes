{
  "name": "kendo-themes.repo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "./packages/html",
    "./packages/core",
    "./packages/default",
    "./packages/bootstrap",
    "./packages/classic",
    "./packages/material",
    "./packages/fluent",
    "./packages/meridian",
    "./packages/utils"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/core": "^20.1.0",
    "@csstools/selector-specificity": "^6.0.0",
    "@eslint/js": "^10.0.1",
    "@jridgewell/source-map": "^0.3.10",
    "@progress/kendo-e2e": "4.14.2",
    "@progress/kendo-svg-icons": "file:.local-deps/progress-kendo-svg-icons-4.9.0-dev.2.tgz",
    "@stylistic/stylelint-plugin": "^5.0.1",
    "@types/node": "^25.0.3",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.27.0",
    "eslint": "^10.0.2",
    "glob": "^13.0.0",
    "globals": "^17.3.0",
    "gulp": "^5.0.0",
    "http-server": "^14.1.1",
    "husky": "^9.0.10",
    "jsdom": "^28.1.0",
    "lerna": "^9.0.0",
    "lint-staged": "^16.0.0",
    "nunjucks": "^3.2.3",
    "nx": "^22.0.1",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "postcss-selector-parser": "^7.1.0",
    "sass": "^1.93.3",
    "sass-embedded": "^1.93.3",
    "sassdoc": "^2.7.4",
    "semver": "^7.3.7",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "sass": "^1.63.6",
    "sass-embedded": "^1.63.6"
  },
  "scripts": {
    "prepare": "husky",
    "start": "node ./scripts/start-dev-server.js",
    "lint": "npm run lint:scripts && npm run lint:styles",
    "lint:scripts": "eslint \"**/*.{js,jsx,ts,tsx,mjs}\"",
    "lint:styles": "stylelint \"**/*.scss\"",
    "lint:staged": "lint-staged --verbose",
    "build": "nx run @progress/kendo-themes-html:build",
    "build:tests": "nx run @progress/kendo-themes-html:build:tests",
    "sass": "nx run-many -t sass",
    "sass:dist": "nx run-many -t sass:dist",
    "docs": "nx run-many -t docs",
    "docs:check": "nx run-many -t docs:check",
    "test:html": "npm run test --prefix packages/html",
    "test:render-test-pages": "node ./scripts/render-test-pages.mjs",
    "test:a11y": "node ./scripts/test-a11y-unified.mjs",
    "test:a11y:affected": "node ./scripts/test-a11y-unified.mjs --affected",
    "test:contrast": "node ./scripts/test-contrast.mjs",
    "test:create-screenshots": "./build/create-screenshots.sh",
    "test:integrations": "npm run build --prefix integrations",
    "test:units": "npm run test --prefix units",
    "test:units:watch": "npm run test:watch --prefix units",
    "clean": "nx reset && find . -name \"node_modules\" -type d -prune | xargs rm -rf",
    "clean:dist": "find ./packages -name \"dist\" -type d -prune -maxdepth 2 | xargs rm -rf",
    "clean:tests": "node ./scripts/cleanup-test-results.js"
  },
  "engines": {
    "node": "^24 || ^25"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs}": "eslint",
    "*.{css,scss}": "stylelint"
  }
}
