%% Kendo Themes Monorepo Architecture
%% Generated for Copilot Crawl Track - Exercise 01

graph TD
    subgraph Foundation["Foundation Layer"]
        core["@progress/kendo-theme-core<br/>━━━━━━━━━━━━━━━━━━━<br/>• Design tokens<br/>• Variables (null defaults)<br/>• Mixins & Functions<br/>• Component skeletons"]
    end

    subgraph Themes["Theme Implementations"]
        default["@progress/kendo-theme-default<br/>Default Theme"]
        bootstrap["@progress/kendo-theme-bootstrap<br/>Bootstrap Theme"]
